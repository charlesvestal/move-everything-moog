{
  "title": "RaffoSynth",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Monophonic synth",
        "with Moog ladder",
        "filter.",
        "",
        "4 oscillators with",
        "4 waveforms each.",
        "Dual ADSR envelopes",
        "(amp + filter).",
        "LFO and glide.",
        "",
        "Last-note priority",
        "with legato glide.",
        "",
        "14 factory presets."
      ]
    },
    {
      "title": "Controls",
      "children": [
        {
          "title": "Knob Mapping",
          "lines": [
            "Knob 1: Cutoff",
            "Knob 2: Resonance",
            "Knob 3: Contour",
            " (filter env depth)",
            "Knob 4: Attack",
            "Knob 5: Decay",
            "Knob 6: Sustain",
            "Knob 7: Release",
            "Knob 8: Glide"
          ]
        },
        {
          "title": "Oscillators",
          "lines": [
            "4 oscillators, each",
            "with:",
            "",
            "Wave: Triangle, Saw,",
            " Sawtooth, Square,",
            " Pulse",
            "",
            "Volume: mix level",
            " (0 = disabled)",
            "",
            "Range: -2 to +2",
            " octaves",
            "",
            "Detune (Osc 2-4):",
            " +/- 50 cents fine",
            " pitch adjust",
            "",
            "Mix all 4 plus",
            "white noise for",
            "rich timbres."
          ]
        },
        {
          "title": "Filter",
          "lines": [
            "4-pole Moog ladder",
            "lowpass filter.",
            "",
            "Cutoff: 20Hz-20kHz",
            "",
            "Resonance: feedback",
            "",
            "Contour: how much",
            " the filter envelope",
            " moves the cutoff",
            "",
            "Key Follow: filter",
            " tracks keyboard",
            " pitch"
          ]
        },
        {
          "title": "Envelopes",
          "lines": [
            "Amp Envelope:",
            " Attack, Decay,",
            " Sustain, Release",
            " Controls volume.",
            "",
            "Filter Envelope:",
            " F.Attack, F.Decay,",
            " F.Sustain, F.Release",
            " Controls cutoff.",
            " Depth set by",
            " Contour knob."
          ]
        },
        {
          "title": "LFO & Performance",
          "lines": [
            "LFO (sine wave):",
            " Rate: 0.1 to 20 Hz",
            " Pitch: vibrato",
            " Filter: wah/sweep",
            "",
            "Glide: portamento",
            " time between notes",
            "",
            "Mod Wheel (CC 1):",
            " Modulates LFO",
            " depth to pitch",
            " and filter",
            "",
            "Vel Sensitivity:",
            " How much velocity",
            " affects amplitude"
          ]
        }
      ]
    },
    {
      "title": "MIDI",
      "lines": [
        "Monophonic with",
        "last-note priority.",
        "Legato: envelopes",
        "don't retrigger.",
        "",
        "Pitch Bend:",
        " Configurable range",
        "",
        "Mod Wheel (CC 1):",
        " LFO to pitch and",
        " filter",
        "",
        "CC 123: All Notes Off"
      ]
    },
    {
      "title": "Presets",
      "lines": [
        "14 factory presets:",
        "",
        " Init",
        " Soloist",
        " Duet",
        " Trio",
        " Quartet",
        " SonataFlair",
        " SonataFlairSub",
        " AngrySweep",
        " SquarePulse",
        " Whisper",
        " CookedPasta",
        " CookedPasta2",
        " Classic Bass",
        " Sub Bass"
      ]
    }
  ]
}
